---
import MainLayout from "../layouts/MainLayout.astro";
import Nav from "../components/Nav.astro";
import { getCollection } from "astro:content";
import { z } from "zod";

const posts = await getCollection("blog");
const recentPosts = posts
  .sort(
    (a, b) =>
      new Date(b.data.datePublished).getTime() -
      new Date(a.data.datePublished).getTime()
  )
  .slice(0, 3);

const tools = ["Semrush", "Meta Ads", "GA4", "Google Ads", "Next.js", "React.js"];

const GithubRepoSchema = z.object({
  id: z.string(),
  name: z.string(),
  stargazerCount: z.number(),
  forkCount: z.number(),
  description: z.string().nullable(),
  languages: z.object({
    edges: z.array(
      z.object({ node: z.object({ name: z.string(), color: z.string() }) })
    ),
  }),
  url: z.string().url(),
});

const GithubResponseSchema = z.object({
  data: z.object({
    viewer: z.object({
      pinnedItems: z.object({
        edges: z.array(z.object({ node: GithubRepoSchema })),
      }),
    }),
  }),
});

type GithubRepo = z.infer<typeof GithubRepoSchema>;

const githubQuery = `
  query {
    viewer {
      pinnedItems(first: 6) {
        edges {
          node {
            ... on Repository {
              id
              name
              stargazerCount
              forkCount
              description
              languages(first: 1, orderBy: { field: SIZE, direction: DESC }) {
                edges {
                  node {
                    name
                    color
                  }
                }
              }
              url
            }
          }
        }
      }
    }
  }
`;

const githubRes = await fetch("https://api.github.com/graphql", {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
    Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}`,
  },
  body: JSON.stringify({ query: githubQuery }),
});

const parsed = GithubResponseSchema.safeParse(await githubRes.json());
const projects: GithubRepo[] = parsed.success
  ? parsed.data.data.viewer.pinnedItems.edges.map((e) => e.node)
  : [];
---

<html lang="en">
  <MainLayout
    title="Mark Edzel Potane"
    description="A digital marketing specialist with a strong background in Web Development."
  >
    <Nav />
    <main class="container mx-auto max-w-2xl px-4 pt-24 pb-10 space-y-10">

      <!-- Profile -->
      <section class="flex items-start gap-5">
        <div class="flex-shrink-0 w-14 h-14 rounded-full bg-gray-700 text-white flex items-center justify-center font-bold text-lg select-none">
          MP
        </div>
        <div>
          <h1 class="text-xl font-bold mb-1">Mark Edzel Potane</h1>
          <p class="text-sm text-gray-300 mb-4 leading-relaxed">
            A digital marketing specialist with a strong background in Web Development,
            helping businesses grow their online presence through data-driven strategies
            and modern web technologies.
          </p>
          <div class="flex gap-2">
            <a
              href="mailto:markpotanecc@gmail.com"
              class="px-4 py-1.5 bg-gray-100 text-gray-900 text-sm rounded hover:bg-white transition-colors"
            >Email</a>
            <a
              href="tel:+639653865805"
              class="px-4 py-1.5 border border-[#292524] text-sm rounded hover:bg-gray-800 transition-colors"
            >Call / Text</a>
          </div>
        </div>
      </section>

      <hr class="border-[#292524]" />

      <!-- Tools -->
      <section id="about">
        <h2 class="text-sm font-semibold mb-4">🛠️ Tools</h2>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-2">
          {tools.map((tool) => (
            <span class="text-xs text-center border border-[#292524] rounded px-2 py-2 text-gray-400">
              {tool}
            </span>
          ))}
        </div>
      </section>

      <hr class="border-[#292524]" />

      <!-- Socials -->
      <section>
        <h2 class="text-sm font-semibold mb-4">📣 Socials</h2>
        <ul class="flex flex-col gap-2 text-sm">
          <li>
            <a
              href="https://www.linkedin.com/in/mpotane/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-300 hover:underline"
            >LinkedIn →</a>
          </li>
          <li>
            <a
              href="https://github.com/mpotane"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-300 hover:underline"
            >GitHub →</a>
          </li>
          <li>
            <a href="/blog" class="text-gray-300 hover:underline">Blog →</a>
          </li>
        </ul>
      </section>

      <hr class="border-[#292524]" />

      <!-- Blog Posts -->
      <section>
        <h2 class="text-sm font-semibold mb-4">📝 Blog Posts</h2>
        <ul class="flex flex-col gap-3">
          {recentPosts.map((post) => (
            <li>
              <a
                href={`/blog/post/${post.data.slug}`}
                class="text-sm text-gray-200 hover:underline"
              >
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <hr class="border-[#292524]" />

      <!-- Projects -->
      <section id="projects">
        <h2 class="text-sm font-semibold mb-4">📦 Projects</h2>
        <div class="flex flex-col gap-3">
          {projects.map((project) => (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="block border border-[#292524] rounded-lg p-4 hover:border-[#292524] transition-colors"
            >
              <p class="text-sm font-medium mb-1">{project.name}</p>
              <p class="text-xs text-gray-500 mb-3">{project.description}</p>
              <div class="flex items-center gap-3 text-xs text-gray-400">
                <span>★ {project.stargazerCount}</span>
                <span>⑂ {project.forkCount}</span>
                {project.languages.edges[0] && (
                  <span
                    class="px-2 py-0.5 rounded-full text-gray-300"
                    style={`background-color: ${project.languages.edges[0].node.color}22; border: 1px solid ${project.languages.edges[0].node.color}55`}
                  >
                    {project.languages.edges[0].node.name}
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>

    </main>

    <footer class="border-t border-[#292524] mt-10">
      <div class="container mx-auto max-w-2xl px-4 py-6 text-center text-xs text-gray-400">
        © Copyright 2026 @mpotane. All rights reserved.
      </div>
    </footer>
  </MainLayout>
</html>
